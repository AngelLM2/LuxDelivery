# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password
POSTGRES_DB=lux_delivery
DATABASE_URL=postgresql+asyncpg://postgres:your_password@db:5432/lux_delivery

# Redis
REDIS_PASSWORD=your_redis_password
REDIS_URL=redis://:your_redis_password@redis:6379/0

# JWT
SECRET_KEY=your_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Bootstrap
BOOTSTRAP_ADMIN_TOKEN=your_bootstrap_token

# Rate Limiting
AUTH_RATE_LIMIT_MAX_ATTEMPTS=10
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_PER_IP=120
RATE_LIMIT_MAX_PER_USER=300

# App
PRODUCTS_MAX_PAGE_SIZE=100
ANALYTICS_MAX_RANGE_DAYS=93